Процедура ОбработкаПроведения(Отказ,Режим)
	
	Движения.ВКМ_ДополнительныеНачисления.Записывать = Истина;
	Для Каждого ТекСтрокаСписокСотрудников из СписокСотрудников Цикл
		Движение = Движения.ВКМ_ДополнительныеНачисления.Добавить();
		Движение.Сотрудник = ТекСтрокаСписокСотрудников.Сотрудник;
		Движение.ВидРасчета = Перечисления.ВКМ_СпособРасчета.Премия;
		Движение.Результат = ТекСтрокаСписокСотрудников.СуммаПремии * Константы.ВКМ_НДФЛ / 100;

	КонецЦикла;

КонецПроцедуры